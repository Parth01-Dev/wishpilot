generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Wishlist {
  id            Int      @id @default(autoincrement())
  shop          String
  customerId    String?
  guestId       String?
  customerEmail String?
  productId     String
  variantId     String?
  productTitle  String
  productHandle String
  productImage  String?
  vendor        String?
  price         Float?
  createdAt     DateTime @default(now())

  @@index([shop])
  @@index([customerId])
  @@index([guestId])
  @@index([productId])
  @@index([shop, createdAt])
  @@index([shop, customerId, productId])
  @@index([shop, guestId, productId])
}

model ShopSettings {
  id                 Int      @id @default(autoincrement())
  shop               String   @unique
  enableWishlist     Boolean  @default(true)
  showHeartIcon      Boolean  @default(true)
  allowGuestWishlist Boolean  @default(false)
  buttonStyle        String   @default("heart")
  primaryColor       String   @default("#000000")
  buttonPosition     String   @default("product_form")
  showWishlistCount  Boolean  @default(true)
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())
}
