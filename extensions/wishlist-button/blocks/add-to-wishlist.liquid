{% comment %}
  WishPilot — Add to Wishlist product block.
  Merchants drag this onto the product template.
{% endcomment %}

{% assign button_color = block.settings.button_color | default: '#000000' %}
{% assign button_text = block.settings.button_text | default: 'Add to Wishlist' %}
{% assign icon = block.settings.icon | default: 'heart' %}
{% assign alignment = block.settings.alignment | default: 'left' %}

<div
  class="wishpilot-add"
  data-wishpilot-add
  data-product-id="{{ product.id }}"
  data-variant-id="{{ product.selected_or_first_available_variant.id }}"
  data-product-title="{{ product.title | escape }}"
  data-product-handle="{{ product.handle }}"
  data-product-image="{{ product.featured_image | image_url: width: 200 }}"
  data-vendor="{{ product.vendor | escape }}"
  data-price="{{ product.selected_or_first_available_variant.price | money_without_currency }}"
  data-customer-id="{% if customer %}{{ customer.id }}{% endif %}"
  data-customer-email="{% if customer %}{{ customer.email }}{% endif %}"
  style="--wishpilot-color: {{ button_color }}; text-align: {{ alignment }};"
  {{ block.shopify_attributes }}
>
  <button type="button" class="wishpilot-add__button" data-wishpilot-add-btn>
    {% if icon == 'heart' or icon == 'heart_text' %}
      <span class="wishpilot-add__icon" aria-hidden="true">❤️</span>
    {% endif %}
    {% if icon != 'heart' %}
      <span class="wishpilot-add__label">{{ button_text }}</span>
    {% endif %}
  </button>
  <p class="wishpilot-add__toast" data-wishpilot-toast hidden></p>
</div>

{% schema %}
{
  "name": "Add to Wishlist",
  "target": "section",
  "stylesheet": "wishpilot.css",
  "javascript": "wishpilot-add.js",
  "enabled_on": {
  "templates": ["product", "collection"]
  },
  "settings": [
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "icon",
      "label": "Icon",
      "options": [
        { "value": "heart", "label": "Heart only" },
        { "value": "heart_text", "label": "Heart + text" },
        { "value": "text", "label": "Text only" }
      ],
      "default": "heart_text"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Text",
      "default": "Add to Wishlist"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    }
  ]
}
{% endschema %}
